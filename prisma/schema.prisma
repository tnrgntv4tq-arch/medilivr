generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  name          String
  phone         String
  role          String
  address       String?
  lat           Float?
  lng           Float?
  pharmacyName  String?
  pharmacyLicense String?
  isAvailable   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  clientOrders   Order[] @relation("ClientOrders")
  pharmacyOrders Order[] @relation("PharmacyOrders")
  deliveryOrders Order[] @relation("DeliveryOrders")
  reviewsGiven   Review[] @relation("ReviewAuthor")
  reviewsReceived Review[] @relation("ReviewTarget")
  messages       Message[]
  notifications  Notification[]
}

model Order {
  id                String   @id @default(cuid())
  status            String   @default("PENDING")

  prescriptionPath  String
  prescriptionIV    String
  prescriptionKey   String
  prescriptionData  Bytes?

  clientId          String
  client            User     @relation("ClientOrders", fields: [clientId], references: [id])
  clientAddress     String
  clientLat         Float
  clientLng         Float

  pharmacyId        String?
  pharmacy          User?    @relation("PharmacyOrders", fields: [pharmacyId], references: [id])

  deliveryId        String?
  delivery          User?    @relation("DeliveryOrders", fields: [deliveryId], references: [id])

  distance          Float?
  basePrice         Float    @default(2.0)
  pricePerKm        Float    @default(0.5)
  totalPrice        Float?

  stripePaymentId   String?
  paid              Boolean  @default(false)

  deliveryLat       Float?
  deliveryLng       Float?

  notes             String?

  reviews           Review[]
  messages          Message[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Message {
  id        String   @id @default(cuid())

  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])

  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])

  text      String
  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  body      String
  type      String
  orderId   String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read, createdAt])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?

  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])

  authorId  String
  author    User     @relation("ReviewAuthor", fields: [authorId], references: [id])

  targetId  String
  target    User     @relation("ReviewTarget", fields: [targetId], references: [id])

  type      String

  createdAt DateTime @default(now())

  @@unique([orderId, authorId, type])
}
